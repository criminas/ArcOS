<Window
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    Title="ArcOS Deployment"
    Height="520"
    Width="820"
    Background="#0b0f1a"
    Foreground="White"
    WindowStartupLocation="CenterScreen">

    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <TextBlock
            Text="ArcOS Deployment Framework"
            FontSize="26"
            FontWeight="SemiBold"
            Margin="0,0,0,20"/>

        <StackPanel Grid.Row="1" Orientation="Horizontal" Margin="0,0,0,15">
            <TextBlock Text="Profile:" VerticalAlignment="Center" Margin="0,0,10,0"/>
            <ComboBox Name="ProfileBox" Width="200">
                <ComboBoxItem Content="Balanced" IsSelected="True"/>
                <ComboBoxItem Content="Aggressive"/>
            </ComboBox>
        </StackPanel>

        <TextBox
            Name="LogBox"
            Grid.Row="2"
            Background="#111827"
            Foreground="#4ade80"
            FontFamily="Consolas"
            IsReadOnly="True"
            TextWrapping="Wrap"
            VerticalScrollBarVisibility="Auto"/>

        <StackPanel Grid.Row="3" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,20,0,0">
            <Button Name="RunButton" Content="Deploy" Width="100" Margin="0,0,10,0"/>
            <Button Name="ExitButton" Content="Exit" Width="100"/>
        </StackPanel>

    </Grid>
</Window>